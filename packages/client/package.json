{
  "name": "@xpert-ai/client",
  "version": "0.0.3",
  "description": "Client package that uses core and utils",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "bundle": "echo 'Bundle step for client package'",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@xpert-ai/xpert-sdk": "workspace:^",
    "@xpert-ai/utils": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.16.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}