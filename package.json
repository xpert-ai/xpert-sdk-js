{
  "private": true,
  "name": "typescript-monorepo-template",
  "version": "0.1.0",
  "description": "A TypeScript monorepo template with pnpm workspace",
  "scripts": {
    "clean": "tsc-multi --clean",
    "prebuild": "pnpm -F @xpert-ai/* -r prebuild",
    "build": "tsc-multi",
    "postbuild": "pnpm -r -F @xpert-ai/* bundle",
    "packages:dev": "tsc-multi --watch",
    "docs:dev": "pnpm -F docs dev",
    "docs:build": "pnpm -F docs build",
    "test": "CI=1 NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:watch": "NODE_ENV=test vitest --watch",
    "dev": "tsx scripts/dev.mts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci:publish": "pnpm publish -r --no-git-checks",
    "bump-version": "changeset version && pnpm -F @xpert-ai/* prebuild",
    "prepare": "husky",
    "clear:deps": "rm -rf node_modules && pnpm -r exec rm -rf node_modules",
    "examples:basic": "pnpm -F basic-example start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.36.0",
    "@types/node": "^22.16.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.2.0",
    "execa": "^9.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsc-multi": "^1.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}